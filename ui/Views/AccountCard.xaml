<UserControl x:Class="Lumi.Views.AccountCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:Lumi.Converters">

    <UserControl.Resources>
        <conv:TimeToArcConverter x:Key="TimeToArc" />
        <conv:ExpiryColorConverter x:Key="ExpiryColor" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:CodeFormatterConverter x:Key="CodeFormatter" />
    </UserControl.Resources>

    <Border Style="{StaticResource CardStyle}">
        <Grid Margin="16,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- ═══ Left: Issuer + Name ═══ -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,4">
                <!-- Name (display mode) -->
                <TextBlock Text="{Binding Name}"
                           Style="{StaticResource IssuerLabel}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="180"
                           HorizontalAlignment="Left"
                           Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                           MouseLeftButtonDown="OnNameDoubleClick"
                           Cursor="Hand"
                           ToolTip="Double-click to edit" />

                <!-- Name (edit mode) -->
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InlineEditBox}"
                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                         LostFocus="OnEditLostFocus"
                         KeyDown="OnEditKeyDown"
                         x:Name="EditBox" />

                <!-- Issuer subtitle -->
                <TextBlock Text="{Binding Issuer}"
                           Style="{StaticResource AccountLabel}" />
            </StackPanel>

            <!-- ═══ Right: Code + Countdown Ring ═══ -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Code value (click to copy) -->
                <Button Command="{Binding CopyCommand}"
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                    <Grid>
                        <!-- Code display -->
                        <Border x:Name="CodeDisplay"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                CornerRadius="8"
                                Padding="12,6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowCopied}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding Code, Converter={StaticResource CodeFormatter}}"
                                           Style="{StaticResource CodeLabel}" />
                                <TextBlock Text="Click to copy"
                                           Style="{StaticResource HintLabel}"
                                           HorizontalAlignment="Center"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Copied feedback -->
                        <Border x:Name="CopiedFeedback"
                                Background="{DynamicResource SystemFillColorSuccessBrush}"
                                CornerRadius="8"
                                Padding="12,6"
                                Opacity="0"
                                IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowCopied}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ShowCopied}" Value="False">
                                            <Setter Property="Visibility" Value="Hidden" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="✓ Copied"
                                       Style="{StaticResource CodeLabel}"
                                       FontSize="16"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource CodeButton}">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.1" />
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.1" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1" />
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </Style.Triggers>
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform CenterX="40" CenterY="20" />
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Circular countdown ring -->
                <Canvas Width="44" Height="44" Margin="12,0,0,0">
                    <!-- Background ring -->
                    <Ellipse Width="44" Height="44"
                             Stroke="{DynamicResource ControlFillColorDisabledBrush}"
                             StrokeThickness="3"
                             Fill="Transparent" />

                    <!-- Progress arc -->
                    <Path Fill="{DynamicResource SystemAccentColorPrimaryBrush}"
                          Data="{Binding Progress, Converter={StaticResource TimeToArc}}" />

                    <!-- Seconds label -->
                    <TextBlock Text="{Binding SecondsLeft}"
                               Style="{StaticResource TimerLabel}"
                               Foreground="{Binding IsExpiringSoon, Converter={StaticResource ExpiryColor}}"
                               Width="44" Height="44"
                               TextAlignment="Center"
                               Padding="0,14,0,0" />
                </Canvas>
            </StackPanel>

            <!-- ═══ Context Menu ═══ -->
            <Grid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy Code" Command="{Binding CopyCommand}">
                        <MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Copy24" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Edit Name" Command="{Binding StartEditCommand}">
                        <MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Edit24" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Delete" Command="{Binding DeleteCommand}"
                              Foreground="{DynamicResource DangerBrush}">
                        <MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Delete24" />
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </Grid.ContextMenu>
        </Grid>
    </Border>
</UserControl>
