<ui:FluentWindow x:Class="Lumi.Views.AddAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Add Account"
        Width="400" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ExtendsContentIntoTitleBar="True"
        ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="Add Account"
                     ShowMinimize="False" ShowMaximize="False" />

        <!-- Form -->
        <ScrollViewer Grid.Row="1" Margin="24,8,24,0"
                      VerticalScrollBarVisibility="Hidden"
                      CanContentScroll="False">
            <StackPanel>
                <TextBlock Text="Add Account Manually"
                           Style="{StaticResource TitleText}"
                           Margin="0,0,0,20" />

                <!-- Account Name -->
                <TextBlock Text="Account Name" Style="{StaticResource AccountLabel}" Margin="0,0,0,4" />
                <ui:TextBox x:Name="NameBox"
                            PlaceholderText="e.g. user@email.com"
                            Margin="0,0,0,12" />

                <!-- Issuer -->
                <TextBlock Text="Issuer" Style="{StaticResource AccountLabel}" Margin="0,0,0,4" />
                <ui:TextBox x:Name="IssuerBox"
                            PlaceholderText="e.g. GitHub, Google"
                            Margin="0,0,0,12" />

                <!-- Secret Key -->
                <TextBlock Text="Secret Key (Base32)" Style="{StaticResource AccountLabel}" Margin="0,0,0,4" />
                <ui:TextBox x:Name="SecretBox"
                            PlaceholderText="JBSWY3DPEHPK3PXP"
                            Margin="0,0,0,16" />

                <!-- Algorithm -->
                <TextBlock Text="Algorithm" Style="{StaticResource AccountLabel}" Margin="0,0,0,4" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="AlgoSHA1" Content="SHA-1" IsChecked="True" Margin="0,0,16,0" />
                    <RadioButton x:Name="AlgoSHA256" Content="SHA-256" Margin="0,0,16,0" />
                    <RadioButton x:Name="AlgoSHA512" Content="SHA-512" />
                </StackPanel>

                <!-- Digits -->
                <TextBlock Text="Digits" Style="{StaticResource AccountLabel}" Margin="0,0,0,4" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="Digits6" Content="6 digits" IsChecked="True" Margin="0,0,16,0" />
                    <RadioButton x:Name="Digits8" Content="8 digits" />
                </StackPanel>

                <!-- Period -->
                <TextBlock Text="Period" Style="{StaticResource AccountLabel}" Margin="0,0,0,4" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="Period30" Content="30 seconds" IsChecked="True" Margin="0,0,16,0" />
                    <RadioButton x:Name="Period60" Content="60 seconds" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Border Grid.Row="2" Padding="24,12"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource ToolbarButton}"
                        Click="OnCancel" Margin="0,0,8,0" />
                <Button Content="Add Account"
                        Style="{StaticResource ToolbarButton}"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        Click="OnAdd" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
