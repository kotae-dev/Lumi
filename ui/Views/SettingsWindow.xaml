<ui:FluentWindow x:Class="Lumi.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Settings"
        Width="400" Height="360"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        ExtendsContentIntoTitleBar="True"
        ResizeMode="NoResize">

    <Grid Background="{DynamicResource ApplicationBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Settings"
                     ShowMinimize="False" ShowMaximize="False" />

        <StackPanel Grid.Row="1" Margin="24,8">
            <!-- Theme -->
            <TextBlock Text="Appearance" Style="{StaticResource TitleText}" Margin="0,0,0,12" />

            <TextBlock Text="Theme" Style="{StaticResource AccountLabel}" Margin="0,0,0,4" />
            <ComboBox x:Name="ThemeCombo" Margin="0,0,0,20"
                      SelectionChanged="OnThemeChanged">
                <ComboBoxItem Content="System Default" Tag="system" />
                <ComboBoxItem Content="Dark" Tag="dark" />
                <ComboBoxItem Content="Light" Tag="light" />
            </ComboBox>

            <!-- Clipboard -->
            <TextBlock Text="Security" Style="{StaticResource TitleText}" Margin="0,0,0,12" />

            <TextBlock Text="Clear clipboard after (seconds)" Style="{StaticResource AccountLabel}" Margin="0,0,0,4" />
            <ui:TextBox x:Name="ClipboardClearBox" Text="30" Margin="0,0,0,16" />

            <!-- About -->
            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Lumi v1.0.0" Style="{StaticResource IssuerLabel}" />
                    <TextBlock Text="A modern Windows TOTP authenticator"
                               Style="{StaticResource AccountLabel}" />
                    <TextBlock Text="© 2026 Lumos Studios"
                               Style="{StaticResource HintLabel}"
                               FontSize="11" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
