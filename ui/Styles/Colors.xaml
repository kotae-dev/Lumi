<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ Brushes mapped to WPF-UI dynamic resources ═══ -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource ApplicationBackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource CardBackgroundFillColorDefaultColor}" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource ControlFillColorDefaultColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource CardStrokeColorDefaultColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextFillColorPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextFillColorSecondaryColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource SystemAccentColorPrimary}" />
    
    <!-- Custom Brushes based on transparency or specific uses -->
    <SolidColorBrush x:Key="AccentDimBrush" Color="{DynamicResource SystemAccentColorLight3}" Opacity="0.2" />
    <SolidColorBrush x:Key="DangerBrush" Color="{DynamicResource SystemFillColorCriticalColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SystemFillColorSuccessColor}" />

    <!-- Titlebar / Toolbar -->
    <SolidColorBrush x:Key="TitleBarBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ToolbarBrush" Color="Transparent" />

    <!-- Ring -->
    <SolidColorBrush x:Key="RingTrackBrush" Color="{DynamicResource ControlFillColorDisabledColor}" />
    <SolidColorBrush x:Key="RingActiveBrush" Color="{DynamicResource SystemAccentColorPrimary}" />

    <!-- Card hover -->
    <SolidColorBrush x:Key="CardHoverBrush" Color="{DynamicResource ControlFillColorSecondaryColor}" />

</ResourceDictionary>
